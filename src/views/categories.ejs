<%- include('partials/header') %>
<main>
    <section class="page-intro">
        <h1><%= title %></h1>
        <p>Explore service opportunities by category. Select a category below to see related projects and active organizations.</p>
    </section>

    <div class="categories-grid">
        <% categories.forEach(category => { %>
            <div class="category-card">
                <h3><%= category.name %></h3>
                <a href="/projects" class="btn-card">View Projects</a>
            </div>
        <% }); %>
    </div>
</main>
<%- include('partials/footer') %>