<%- include('partials/header') %>
<main>
    <section class="project-details">
        <h1><%= title %></h1>
        <p class="project-org">
            Organized by: <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>
        </p>

        <% if (categories && categories.length > 0) { %>
            <div class="project-tags" style="margin-bottom: 20px;">
                <% categories.forEach(category => { %>
                    <a href="/category/<%= category.category_id %>" class="project-badge" style="display: inline-block; padding: 5px 10px; margin-right: 8px; border-radius: 4px; text-decoration: none; font-size: 0.9em; background-color: #f1f3f5; color: #495057; border: 1px solid #dee2e6;"><%= category.name %></a>
                <% }) %>
            </div>
        <% } %>

        <% if (user && user.role === 'admin') { %>
            <div class="action-buttons-group" style="margin-bottom: 2rem; display: flex; gap: 0.75rem;">
                <a href="/assign-categories/<%= project.project_id %>" class="btn btn-secondary">Edit Categories</a>
                <a href="/edit-project/<%= project.project_id %>" class="btn btn-primary">Edit Project Details</a>
            </div>
        <% } %>

        <p class="project-description"><%= project.description %></p>
        <div class="project-meta-details">
            <p>📍 <strong>Location:</strong> <%= project.location %></p>
            <p>📅 <strong>Date:</strong> <%= new Date(project.date).toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
        </div>

        <% if (user) { %>
            <div class="volunteer-section" style="margin-top: 1.5rem; padding: 1.25rem; border: 1px solid #dee2e6; border-radius: 8px; background-color: #f8f9fa;">
                <% if (isVolunteering) { %>
                    <p style="margin-bottom: 0.75rem; font-weight: 600; color: #2e7d32;">✅ You are volunteering for this project!</p>
                    <form action="/unvolunteer/<%= project.project_id %>" method="POST">
                        <input type="hidden" name="redirectTo" value="/project/<%= project.project_id %>">
                        <button type="submit" class="btn btn-secondary">Remove Myself as Volunteer</button>
                    </form>
                <% } else { %>
                    <p style="margin-bottom: 0.75rem;">Want to help out? Sign up to volunteer for this project.</p>
                    <form action="/volunteer/<%= project.project_id %>" method="POST">
                        <button type="submit" class="btn btn-primary">Volunteer for This Project</button>
                    </form>
                <% } %>
            </div>
        <% } %>

        <br>
        <a href="/projects" class="btn btn-secondary">Back to Upcoming Projects</a>
    </section>
</main>
<%- include('partials/footer') %>
