<%- include('partials/header') %>
<main>
    <section class="page-intro">
        <h1><%= title %></h1>
        <p>Explore current volunteer-led community initiatives and service learning projects available for enrollment.</p>
    </section>

    <div class="projects-grid">
        <% projects.forEach(project => { %>
            <div class="project-card">
                <h3><a href="/project/<%= project.project_id %>"><%= project.title %></a></h3>
                <p class="org-name">by <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
                <p class="project-description"><%= project.description %></p>
                <div class="project-meta">
                    <span>📍 <%= project.location %></span>
                    <span>📅 <%= new Date(project.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></span>
                </div>
                <a href="/project/<%= project.project_id %>" class="btn-card">Learn More</a>
            </div>
        <% }); %>
    </div>
    <p><a href="/new-project">Add a New Service Project</a></p>
</main>
<%- include('partials/footer') %>